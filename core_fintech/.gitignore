# ==========================================
# SECRET ENVIRONMENT VARIABLES (CRITICAL)
# ==========================================
.env
.env.local
.env.*

# ==========================================
# PYTHON VIRTUAL ENVIRONMENTS
# ==========================================
.venv/
venv/
env/
ENV/

# ==========================================
# PYTHON CACHE FILES
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class

# ==========================================
# DJANGO SPECIFIC
# ==========================================
db.sqlite3
db.sqlite3-journal
staticfiles/
media/
local_settings.py

# ==========================================
# OS & IDE GENERATED FILES
# ==========================================
.DS_Store
.DS_Store?
.vscode/
.idea/
*.swp
Thumbs.db

# NOTE: We intentionally are NOT ignoring *.pkl files 
# because Render needs your credit_scoring_model.pkl to run!
